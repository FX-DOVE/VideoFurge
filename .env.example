# Copy to .env or export in shell / systemd / pm2 env
# Core bins (adjust for your VPS)
GROK_BIN=grok
WHISPER_BIN=/opt/whisper.cpp/main
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-base.en.bin

# Server
PORT=3000
# Comma separated valid API keys. Clients send X-API-Key: <one-of-these>
API_KEYS=change-me-to-long-random,another-key-optional
MAX_JOBS_PER_DAY=3
MAX_SCRIPT_CHARS=8000
MAX_DISK_BYTES=30000000000

# Job lifecycle
JOB_TTL_HOURS=48

# Optional: more ffmpeg / grok tuning if exposed
# GROK_TIMEOUT_MS=300000

# ---------------------------------------------------------------------------
# Google Drive durable storage (optional)
# When GOOGLE_DRIVE_ENABLED=false (default), behavior is local-only (legacy).
# When true, worker uploads finals to Drive, stores metadata in MongoDB, then
# deletes local generated videos. Download/preview stream from Drive if local
# file is gone. BOTH pipeline-server and pipeline-worker need the same env.
# ---------------------------------------------------------------------------
GOOGLE_DRIVE_ENABLED=false

# Personal Gmail: use oauth (service accounts cannot store files in My Drive).
# Workspace Shared drives can use service_account.
GOOGLE_DRIVE_AUTH_MODE=oauth

# Absolute path to service account JSON (only for Workspace Shared drives).
GOOGLE_APPLICATION_CREDENTIALS=

# Drive folder ID (owned by the Gmail you sign in with for OAuth)
GOOGLE_DRIVE_FOLDER_ID=

# GCP project id
GOOGLE_PROJECT_ID=

# OAuth Desktop client (required for personal Gmail) — create in Cloud Console
# then run: npm run drive:oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_PATH=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3333/oauth2callback

# MongoDB for asset metadata (required when Drive enabled)
MONGODB_URI=
MONGODB_DB=videofurge
# MONGODB_ASSETS_COLLECTION=job_assets

# Optional storage tuning
# GOOGLE_DRIVE_TRASH_ON_DELETE=true
# STORAGE_MAX_UPLOAD_RETRIES=5
# STORAGE_UPLOAD_RETRY_MS=1000
# STORAGE_CREATE_JOB_FOLDERS=true
# STORAGE_VERIFY_SIZE=true
#
# When Drive is enabled, by default we upload ALL job outputs:
# final/acted/edited/concat, images.zip, every clip_*.mp4, every frame_*.png,
# transcript.json, captions.ass, audio stems, screenplay, edit timeline, refs.
# STORAGE_UPLOAD_ALL_OUTPUTS=true
# STORAGE_UPLOAD_CLIPS=true
# STORAGE_UPLOAD_FRAMES=true
# STORAGE_UPLOAD_TRANSCRIPT=true
# STORAGE_UPLOAD_AUDIO=true
# STORAGE_UPLOAD_DOCS=true
# STORAGE_CLEANUP_INTERMEDIATES=true
