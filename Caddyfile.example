# Caddy reverse proxy example (auto HTTPS + LE)
# Place at /etc/caddy/Caddyfile or alongside, adapt domain + port.
# Caddy is lightweight and great on small VPS.

videofurge.voiceforgeai.site {
    # Optional: basic rate limit at proxy too
    reverse_proxy localhost:3001   # or whatever PORT you run the server on (default 3000, current PM2 uses 3001)

    # Logging
    log {
        output file /var/log/caddy/pipeline.log
        format json
    }
}

# If you want to serve the static assets or downloads with longer cache:
# handle_path /api/jobs/*/download/* {
#    reverse_proxy localhost:3000
# }
