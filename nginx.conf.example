# nginx reverse proxy + HTTPS (Let's Encrypt via certbot)
# Basic template. Put in /etc/nginx/sites-available/videofurge , symlink to sites-enabled.
# After: sudo certbot --nginx -d videofurge.voiceforgeai.site
#
# Note: Your current setup uses non-standard ports (8088/8443) because docker is on 80/443.
# Adapt listen ports + server_name as needed. Proxy to the port your VideoFurge server runs on (3001 via current PM2).

server {
    listen 8088;
    server_name videofurge.voiceforgeai.site;

    # redirect all HTTP to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 8443 ssl http2;
    server_name videofurge.voiceforgeai.site;

    # ssl_certificate /etc/letsencrypt/live/videofurge.voiceforgeai.site/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/videofurge.voiceforgeai.site/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Proxy to node (never expose the node port publicly)
    location / {
        proxy_pass http://127.0.0.1:3001;   # <-- match your PORT (ecosystem.config or .env)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 3600s;
    }

    # Optional: larger upload size if 2hr media
    client_max_body_size 3G;
}
